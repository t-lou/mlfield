{
  "name": "mlfield",
  "dockerComposeFile": "../.devcontainer/docker-compose.yml",
  "service": "mlfield",
  "workspaceFolder": "/repo",

  "remoteUser": "${localEnv:USERNAME}",

  "initializeCommand": ".devcontainer/detect-platform.sh",

  "build": {
    "args": {
      "HOST_UID": "${localEnv:UID}",
      "HOST_GID": "${localEnv:GID}",
      "USERNAME": "${localEnv:USERNAME}",
      "BASE_IMAGE": "${localEnv:BASE_IMAGE:-mlfield_cuda_base:latest}"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python"
      ]
    }
  },

  "remoteEnv": {
    "PYTHONUNBUFFERED": "1",
    "PIP_DISABLE_PIP_VERSION_CHECK": "1"
  }
}